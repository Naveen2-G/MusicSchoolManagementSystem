NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<dbName>?retryWrites=true&w=majority
# Optional fallback key supported by backend
# MONGODB_URI=

JWT_SECRET=some-very-strong-random-secret
JWT_EXPIRES_IN=7d

ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@musicschool.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@12345

FRONTEND_URL=https://musicschoolmanagementsystem.vercel.app
CORS_ORIGINS=https://musicschoolmanagementsystem.vercel.app
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
